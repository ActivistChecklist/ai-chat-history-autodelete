{
  "manifest_version": 3,
  "name": "AI Chat History Auto-Delete",
  "version": "1.0.0",
  "description": "Auto-delete older chats on claude.ai by age threshold. Unofficial; not affiliated with Anthropic. Privacy-focused; runs locally.",
  "permissions": [
    "storage",
    "alarms",
    "tabs",
    "scripting",
    "notifications"
  ],
  "host_permissions": [
    "https://claude.ai/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "action": {
    "default_title": "AI Chat History Auto-Delete",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://claude.ai/*"
      ],
      "js": [
        "src/content/top-bar.js"
      ],
      "css": [
        "src/content/top-bar.css"
      ],
      "run_at": "document_end"
    }
  ],
  "options_page": "src/options/options.html",
  "web_accessible_resources": [
    {
      "resources": [
        "src/shared/pending-deletion-modal.js",
        "src/shared/constants.js",
        "src/shared/bar-insertion.js"
      ],
      "matches": [
        "https://claude.ai/*"
      ]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}